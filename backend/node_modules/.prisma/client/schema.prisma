generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  KEPALA_KELUARGA
  ISTRI
  ANAK
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String
  image                String?
  role                 UserRole              @default(ANAK)
  familyId             String?
  family               Family?               @relation(fields: [familyId], references: [id])
  wallets              Wallet[]
  tasksAssigned        Task[]                @relation("AssignedTasks")
  tasksCreated         Task[]                @relation("CreatedTasks")
  transactions         Transaction[]
  notifications        Notification[]
  favoriteTransactions FavoriteTransaction[]
  needsPasswordChange  Boolean               @default(false)
  twoFactorEnabled     Boolean               @default(false)
  allowanceLimit       Decimal?              @db.Decimal(20, 2)
  resetToken           String?               @unique
  resetTokenExpires    DateTime?
  status               String?
  statusIcon           String?
  isFirstLogin         Boolean               @default(true)
  lastLoginAt          DateTime?
  lastIp               String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  auditLogs            AuditLog[]
  joinRequests         FamilyJoinRequest[]
  walletPermissions    WalletPermission[]
  islamicHabits        IslamicHabit[]
  fastingLogs          FastingLog[]
  quranKhatams         QuranKhatam[]
  prayerLogs           PrayerLog[]
  chatMessages         ChatMessage[]
  reminders            Reminder[]
  taskComments         TaskComment[]
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  ip        String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Family {
  id                   String                @id @default(cuid())
  name                 String
  currency             String                @default("IDR")
  members              User[]
  invitations          FamilyInvitation[]
  joinRequests         FamilyJoinRequest[]
  budgets              Budget[]
  savingsGoals         SavingsGoal[]
  favoriteTransactions FavoriteTransaction[]
  snapshots            BalanceSnapshot[]
  debts                Debt[]
  customCategories     CustomCategory[]
  waqaf                Waqaf[]
  transactions         Transaction[]
  zakatLogs            ZakatLog[]
  chatMessages         ChatMessage[]
  syuraNotes           SyuraNote[]
  syuraTopics          SyuraTopic[]
  reminders            Reminder[]
  barakahScore         Int                   @default(0)
  achievements         Json?                 @default("[]")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  bills                Bill[]                @relation("FamilyBills")
}

model FamilyJoinRequest {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  familyId  String
  family    Family        @relation(fields: [familyId], references: [id])
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model FamilyInvitation {
  id        String   @id @default(cuid())
  email     String
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])
  token     String   @unique
  role      UserRole @default(ANAK)
  expiresAt DateTime
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Wallet {
  id                String             @id @default(cuid())
  name              String
  balance           Decimal            @default(0) @db.Decimal(20, 2)
  currency          String             @default("IDR")
  type              String             @default("CASH")
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  familyId          String
  transactions      Transaction[]      @relation("SourceWallet")
  receivedTransfers Transaction[]      @relation("TargetWallet")
  permissions       WalletPermission[]
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  bills             Bill[]             @relation("WalletBills")
}

model Bill {
  id           String         @id @default(cuid())
  name         String
  amount       Decimal        @db.Decimal(20, 2)
  dueDate      DateTime
  recurrence   RecurrenceType @default(MONTHLY)
  category     String
  familyId     String
  family       Family         @relation("FamilyBills", fields: [familyId], references: [id])
  isPaid       Boolean        @default(false)
  autoPay      Boolean        @default(false)
  walletId     String?
  wallet       Wallet?        @relation("WalletBills", fields: [walletId], references: [id])
  tasks        Task[]         @relation("BillTasks")
  transactions Transaction[]  @relation("BillTransactions")

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id             String            @id @default(cuid())
  amount         Decimal           @db.Decimal(20, 2)
  type           TransactionType
  category       String
  description    String?
  billId         String?
  bill           Bill?             @relation("BillTransactions", fields: [billId], references: [id])
  tags           String[]
  attachmentUrl  String?
  location       Json?
  date           DateTime          @default(now())
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  walletId       String
  wallet         Wallet            @relation("SourceWallet", fields: [walletId], references: [id])
  targetWalletId String?
  targetWallet   Wallet?           @relation("TargetWallet", fields: [targetWalletId], references: [id])
  savingsGoalId  String?
  savingsGoal    SavingsGoal?      @relation(fields: [savingsGoalId], references: [id])
  familyId       String
  family         Family            @relation(fields: [familyId], references: [id])
  metadata       Json?
  isDeleted      Boolean           @default(false)
  deletedAt      DateTime?
  status         TransactionStatus @default(HALAL)
  createdAt      DateTime          @default(now())
}

model Waqaf {
  id          String   @id @default(cuid())
  name        String
  amount      Decimal  @db.Decimal(20, 2)
  type        String // e.g., TUNAI, ASSET
  description String?
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id])
  createdAt   DateTime @default(now())
}

enum TransactionStatus {
  HALAL
  SUBHAT
  HARAM
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model ZakatLog {
  id          String   @id @default(cuid())
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id])
  amount      Decimal  @db.Decimal(20, 2)
  type        String
  nisabAtTime Decimal  @db.Decimal(20, 2)
  goldPrice   Decimal  @db.Decimal(20, 2)
  recipient   String?
  notes       String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Task {
  id          String              @id @default(cuid())
  title       String
  description String?
  status      TaskStatus          @default(PENDING)
  priority    TaskPriority        @default(MEDIUM)
  category    String?             @default("Lainnya")
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?               @relation("AssignedTasks", fields: [assigneeId], references: [id])
  creatorId   String
  creator     User                @relation("CreatedTasks", fields: [creatorId], references: [id])
  familyId    String
  isDeleted   Boolean             @default(false)
  deletedAt   DateTime?
  checklists  TaskChecklistItem[]
  comments    TaskComment[]
  attachments TaskAttachment[]
  // Hierarchy (Task 357)
  parentId    String?
  parent      Task?               @relation("SubTasks", fields: [parentId], references: [id])
  subTasks    Task[]              @relation("SubTasks")

  // Planning & Privacy (Task 359, 360, 366, 373)
  isPrivate     Boolean @default(false)
  estimatedTime Int? // In minutes
  isSOS         Boolean @default(false)
  color         String? // Hex code or color name

  // Dependencies (Task 363)
  dependencies Task[] @relation("TaskDependencies")
  dependents   Task[] @relation("TaskDependencies")

  // Integration (Task 376, 377)
  billId String?
  bill   Bill?   @relation("BillTasks", fields: [billId], references: [id])

  // Recurrence & Reminders
  recurrence      RecurrenceType @default(NONE)
  dueReminderSent Boolean        @default(false)
  lastEditedById  String?
  lastEditedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAttachment {
  id        String   @id @default(cuid())
  url       String
  name      String
  type      String   @default("IMAGE")
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  createdAt DateTime @default(now())
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model TaskChecklistItem {
  id        String   @id @default(cuid())
  title     String
  isDone    Boolean  @default(false)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  createdAt DateTime @default(now())
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, SYSTEM
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  familyId  String?
  createdAt DateTime @default(now())
}

model Budget {
  id        String   @id @default(cuid())
  category  String
  amount    Decimal  @db.Decimal(20, 2)
  period    String // Format: YYYY-MM
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([familyId, category, period])
}

model SavingsGoal {
  id            String        @id @default(cuid())
  name          String
  targetAmount  Decimal       @db.Decimal(20, 2)
  currentAmount Decimal       @default(0) @db.Decimal(20, 2)
  deadline      DateTime?
  familyId      String
  family        Family        @relation(fields: [familyId], references: [id])
  transactions  Transaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model FavoriteTransaction {
  id          String          @id @default(cuid())
  name        String
  amount      Decimal         @db.Decimal(20, 2)
  type        TransactionType
  category    String
  description String?
  walletId    String
  userId      String
  familyId    String
  user        User            @relation(fields: [userId], references: [id])
  family      Family          @relation(fields: [familyId], references: [id])
  createdAt   DateTime        @default(now())
}

model BalanceSnapshot {
  id       String   @id @default(cuid())
  walletId String
  amount   Decimal  @db.Decimal(20, 2)
  date     DateTime @default(now())
  familyId String
  family   Family   @relation(fields: [familyId], references: [id])

  @@index([familyId, date])
}

enum DebtType {
  DEBT
  RECEIVABLE
}

model Debt {
  id          String    @id @default(cuid())
  personName  String
  amount      Decimal   @db.Decimal(20, 2)
  type        DebtType
  description String?
  dueDate     DateTime?
  isPaid      Boolean   @default(false)
  familyId    String
  family      Family    @relation(fields: [familyId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CustomCategory {
  id        String           @id @default(cuid())
  name      String
  type      TransactionType? // INCOME, EXPENSE, or both
  icon      String?
  familyId  String
  family    Family           @relation(fields: [familyId], references: [id])
  createdAt DateTime         @default(now())

  @@unique([familyId, name])
}

model WalletPermission {
  id        String   @id @default(cuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  canView   Boolean  @default(true)
  canEdit   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([walletId, userId])
}

model IslamicHabit {
  id          String   @id @default(cuid())
  name        String // e.g., Tahajjud, Duha, Sedekah Subuh
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

model FastingLog {
  id        String   @id @default(cuid())
  type      String // e.g., RAMADHAN, SUNNAH, QADHA
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model QuranKhatam {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  currentJuz  Int       @default(0)
  targetDate  DateTime?
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model PrayerLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  prayerName String // e.g., SUBUH, DHUHUR, ASHAR, MAGHRIB, ISYA
  date       DateTime @default(now())
  isOnTime   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model IslamicEvent {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  description String?
  type        String // e.g., HOLIDAY, REMINDER
  createdAt   DateTime @default(now())
}

model SyuraNote {
  id        String   @id @default(cuid())
  title     String
  date      DateTime @default(now())
  content   String // MD formatted decisions
  attendees String[] // Names or User IDs
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])
  createdAt DateTime @default(now())
}

model SyuraTopic {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  familyId  String
  title     String
  content   String?
  remindAt  DateTime
  isSent    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  family Family @relation(fields: [familyId], references: [id])
}

model ChatMessage {
  id       String  @id @default(cuid())
  content  String // This will be encrypted (Task 298)
  role     String  @default("user") // "user" or "assistant"
  userId   String?
  user     User?   @relation(fields: [userId], references: [id])
  familyId String?
  family   Family? @relation(fields: [familyId], references: [id])

  isPinned      Boolean @default(false)
  reactions     Json? // Format: { "👍": ["userId1", "userId2"], "❤️": [...] }
  attachmentUrl String?
  metadata      Json? // Task 304, 305: Link Preview, Poll Data, etc.
  isModerated   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([familyId])
}
