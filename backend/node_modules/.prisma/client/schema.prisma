// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  KEPALA_KELUARGA
  ISTRI
  ANAK
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  role          UserRole       @default(ANAK)
  familyId      String?
  family        Family?        @relation(fields: [familyId], references: [id])
  wallets       Wallet[]
  tasksAssigned Task[]         @relation("AssignedTasks")
  tasksCreated  Task[]         @relation("CreatedTasks")
  transactions  Transaction[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Family {
  id        String   @id @default(cuid())
  name      String
  members   User[]
  wallets   Wallet[]
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wallet {
  id           String        @id @default(cuid())
  name         String
  balance      Decimal       @default(0) @db.Decimal(20, 2)
  currency     String        @default("IDR")
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  familyId     String
  family       Family        @relation(fields: [familyId], references: [id])
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?

  @@index([familyId])
  @@index([userId])
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Decimal         @db.Decimal(20, 2)
  type        TransactionType
  category    String
  description String?
  date        DateTime        @default(now())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  walletId    String
  wallet      Wallet          @relation(fields: [walletId], references: [id])
  metadata    Json? // For extensible data like "isZakat", "isHalalMerchant", etc.
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  isDeleted   Boolean         @default(false)
  deletedAt   DateTime?

  @@index([userId])
  @@index([walletId])
  @@index([date])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("Medium")
  isCompleted Boolean   @default(false)
  familyId    String
  family      Family    @relation(fields: [familyId], references: [id])
  creatorId   String
  creator     User      @relation("CreatedTasks", fields: [creatorId], references: [id])
  assigneeId  String?
  assignee    User?     @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  @@index([familyId])
  @@index([assigneeId])
}

model ZakatLog {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(20, 2)
  type        String // Maal, Fitrah, Profesi
  nisabAtTime Decimal  @db.Decimal(20, 2)
  goldPrice   Decimal  @db.Decimal(20, 2)
  date        DateTime @default(now())
  familyId    String
  createdAt   DateTime @default(now())
}

model FamilyInvitation {
  id        String   @id @default(cuid())
  email     String
  familyId  String
  role      UserRole
  token     String   @unique
  expiresAt DateTime
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("info") // info, warning, finance, task
  createdAt DateTime @default(now())

  @@index([userId])
}
