# ════════════════════════════════════════════════════════
# Yumna Family Finance — Environment Variables Template
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASS@HOST:5432/yumna_db?schema=public"
# DATABASE_REPLICA_URL=postgresql://USER:PASS@REPLICA_HOST:5432/yumna_db

# ── Auth ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change_me_min_32_chars_random_string"
JWT_EXPIRY="15m"
REFRESH_TOKEN_SECRET="change_me_min_32_chars_random_string"
NEXTAUTH_SECRET="change_me_min_32_chars_random_string"
NEXTAUTH_URL="https://yumna.my.id"

# ── AI ────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY="AIzaSy..."

# ── Security ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY="change_me_min_32_chars_for_AES256"

# ── Application ──────────────────────────────────────────
NODE_ENV="production"
PORT=3001
ALLOWED_ORIGINS="https://yumna.my.id"

# ── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://api.yumna.my.id"
NEXT_PUBLIC_APP_NAME="Yumna"
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ── Monitoring & Alerts (optional) ───────────────────────
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
